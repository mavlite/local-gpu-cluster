# config.env — central configuration for local-gpu-cluster bootstrap (V620-only).
# Copy this to config.env and adjust values for your hardware.
#
# Every value has a sane default; uncomment to override.

# ---------- LXC VMIDs ----------
# V620-only: LXC 152 (the old 3060 LXC) has been removed.
# AMD_VMID=151
# ROUTER_VMID=153
# ANYTHINGLLM_VMID=154
# MCP_VMID=155

# ---------- hostnames ----------
# AMD_HOSTNAME=llamacpp-amd
# ROUTER_HOSTNAME=llm-router
# ANYTHINGLLM_HOSTNAME=anythingllm
# MCP_HOSTNAME=mcp-stack

# ---------- LXC sizing ----------
# AMD_CORES=8         ; AMD_MEMORY=32768 ; AMD_SWAP=8192 ; AMD_ROOTFS_SIZE=64
# ROUTER_CORES=2      ; ROUTER_MEMORY=4096  ; ROUTER_ROOTFS_SIZE=8
# ANYTHINGLLM_CORES=4 ; ANYTHINGLLM_MEMORY=16384 ; ANYTHINGLLM_ROOTFS_SIZE=32
# (8 GB starved with 700+ docs across multiple workspaces under heavy ingest;
# 16 GB + 2 GB swap is the safe baseline. Bump higher for 5k+ doc corpora.)
# MCP_CORES=2         ; MCP_MEMORY=4096  ; MCP_ROOTFS_SIZE=16

# ---------- networking ----------
# BRIDGE=vmbr0
# Static IPs assumed for service routing. Either reserve via DHCP or set explicit IPs.
# The router LXC reads V620_URL / EMBED_URL / RERANK_URL from /etc/router.env.
# AMD_IP=192.168.6.151
# ROUTER_IP=192.168.6.153
# ANYTHINGLLM_IP=192.168.6.154
# MCP_IP=192.168.6.155

# ---------- storage ----------
# Path on the host where ZFS pool 'tank' lives (mirror across two NVMes — see Phase 4.8).
# Datasets:
#   tank/models       (read-write bind mount in V620 LXC at /opt/models —
#                      HF cache target for llama-server's --hf-repo downloads)
#   tank/anythingllm  (mounted in 154 at /opt/anythingllm-data)
#   tank/mcp
#   tank/backups
#   tank/.embedder-sha  (file pin recording the canonical embedder GGUF SHA-256)
#   tank/.phase6-embed-trigger  (set during cutover when embedder GGUF changes)
# DATA_NVME_A=/dev/disk/by-id/nvme-XXX   # first data drive (M.2_3)
# DATA_NVME_B=/dev/disk/by-id/nvme-YYY   # second data drive (M.2_4)
# MODELS_DIR=/tank/models
# LXC_STORAGE=local-lvm                  # PVE storage where LXC rootfs live (ext4 LVM-thin)

# ---------- Proxmox template ----------
# Run `pveam available --section system | grep ubuntu-24` to see current versions.
# LXC_TEMPLATE_NAME=ubuntu-24.04-standard_24.04-2_amd64.tar.zst
# LXC_TEMPLATE_STORAGE=local

# ---------- kernel ----------
# V620-only build does not require kernel pinning. PVE 9.1 default 6.17 is fine
# (AMDGPU is in-tree). Historical note: prior runbook revisions pinned to 6.14 for
# NVIDIA DKMS compatibility — no longer relevant. Set PIN_KERNEL only if you have
# a specific reason (e.g., a known AQC113 10 GbE regression on a newer kernel).
# PIN_KERNEL=                            # empty = use PVE default

# ---------- ROCm ----------
# ROCM_RELEASE=latest                    # or pin to '6.4', '7.0', etc.

# ---------- llama.cpp build target (V620 only) ----------
# AMD_GPU_TARGET=gfx1030
# Build flags applied: -DGGML_HIP=ON -DGPU_TARGETS=gfx1030 -DLLAMA_BUILD_SERVER=ON
#                      -DGGML_HIP_GRAPHS=ON -DGGML_OPENMP=ON -DCMAKE_BUILD_TYPE=Release

# ---------- API keys (auto-generated; do not paste real values in this example) ----------
# Both keys are generated by the provisioning scripts (51, 53) and stored in
# /etc/llamacpp.env (on LXC 151) and /etc/router.env (on LXC 153), mode 600.
# They are NOT read from this config.env file — the scripts gen + persist them.
# Documented here for reference only:
#   LLAMACPP_API_KEY        -> /etc/llamacpp.env on LXC 151 (and copied to LXC 153)
#   ROUTER_API_KEY          -> /etc/router.env on LXC 153

# ---------- V620 chat unit tuning (51-lxc-amd.sh -> llamacpp-chat.service) ----------
# Verified on HF 2026-05-17:
#   unsloth/Qwen3.6-35B-A3B-GGUF -> Qwen3.6-35B-A3B-UD-Q4_K_M.gguf (~22 GB)
#   unsloth/Qwen3-0.6B-GGUF      -> Qwen3-0.6B-Q4_K_M.gguf (~400 MB; see spec-decode note below — currently unused)
# LLAMA_HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
# LLAMA_HF_QUANT=UD-Q4_K_M       # Unsloth Dynamic Q4_K_M
# LLAMA_ALIAS=rag-qwen3.6
# LLAMA_CTX=262144               # 256K = Qwen3.6 full trained context (n_ctx_train).
#                                # Per-slot ctx = LLAMA_CTX / LLAMA_PARALLEL.
# LLAMA_KV_TYPE=q8_0             # q4_0 halves KV size if you need more headroom
# LLAMA_PARALLEL=1               # Single in-flight request gets full 256K window.
#                                # Matches router CHAT_CONCURRENCY=1: sub-agent calls
#                                # queue at the router (which emits SSE keepalives)
#                                # instead of inside llama.cpp. At parallel=1 + 256K +
#                                # q8_0 KV, slot KV ≈ 11 GB on top of 22 GB weights.
# LLAMA_CACHE_REUSE=1024         # system-prompt prefix reuse (RAG-aware)
# LLAMA_CACHE_RAM_MB=16384       # 16 GB host-RAM prompt-prefix cache (OpenCode reuse)
# LLAMA_TENSOR_SPLIT=1,1         # equal split across V620 #1 and #2
# LLAMA_THREADS=8
# LLAMA_FLASH_ATTN=auto          # set to 'off' if §5.10 benchmark shows FA regresses on V620

# Speculative-decoding draft (in-process, same HIP backend).
# DISABLED by default. Qwen3.6-35B-A3B has vocab 248,320 while Qwen3-0.6B has vocab
# 151,936 — llama.cpp refuses to load a mismatched-vocab draft ("draft model vocab
# type must match target model"). No vocab-compatible small variant exists in the
# Qwen3.6 family yet, so spec-decode stays off. The chat unit boot log will show
# "common_speculative_init: no implementations specified for speculative decoding" —
# this is the expected/normal state, NOT a bug.
# Qwen3.6-35B-A3B is MoE with ~3 B active params per token, so it's already fast;
# the ~1.5-2× throughput hit from disabled spec-decode is an accepted trade-off
# until a vocab-matched Qwen3.6 small variant becomes available.
# LLAMA_DRAFT_REPO=                       # leave empty unless a vocab-matched draft is available
# LLAMA_DRAFT_QUANT=Q4_K_M
# LLAMA_SPEC_NMAX=16
# LLAMA_SPEC_NMIN=0

# ---------- V620 embed unit (51-lxc-amd.sh -> llamacpp-embed.service) ----------
# EMBED_HF_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
# EMBED_HF_QUANT=Q8_0
# EMBED_ALIAS=qwen3-embed
# NOTE: llama.cpp splits --ctx-size by --parallel. Per-slot ctx MUST be >= the
# largest chunk AnythingLLM will send. Empirical sweet spot for technical docs:
# 65536/4=16384 per slot (covers >97% of real-world chunks). Lower values cause
# silent embed failures on long pages with code blocks or dense tables.
# Pre-pivot defaults (8192/8=1024 per slot) failed ~half of VCF doc embeds.
# EMBED_CTX=65536
# EMBED_PARALLEL=4
# EMBED_BATCH_SIZE=2048
# EMBED_UBATCH_SIZE=512
# EMBED_POOLING=last       # CRITICAL: Qwen3-Embedding requires 'last', NOT 'cls'

# ---------- V620 rerank unit (51-lxc-amd.sh -> llamacpp-rerank.service) ----------
# Default: BGE Reranker v2-m3 via gpustack's ungated GGUF mirror. Qwen/Qwen3-Reranker
# variants are gated on HF (401 without HF_TOKEN + accepted license), so they're not
# the default. If you want Qwen3-Reranker, accept the license, set HF_TOKEN=... in
# /etc/llamacpp.env on LXC 151, and uncomment the alternative below.
# RERANK_HF_REPO=gpustack/bge-reranker-v2-m3-GGUF
# RERANK_HF_QUANT=Q4_K_M
# Alternative (gated, requires HF_TOKEN): RERANK_HF_REPO=Qwen/Qwen3-Reranker-0.6B-GGUF
# RERANK_ALIAS=bge-rerank
# RERANK_CTX=8192
# RERANK_PARALLEL=4
# RERANK_POOLING=rank      # llama.cpp upstream best practice with --reranking

# ---------- Router (53-lxc-router.sh) ----------
# All three URLs point to the V620 LXC. /etc/router.env on LXC 153 gets these.
# V620_URL=http://192.168.6.151:8080
# EMBED_URL=http://192.168.6.151:8082
# RERANK_URL=http://192.168.6.151:8083
# KEEPALIVE_INTERVAL=12
# Admission control + rate limit (router-app.py, todo #20 — rewrite in progress):
# CHAT_CONCURRENCY=1
# EMBED_CONCURRENCY=4
# MAX_CHAT_INPUT_TOKENS=200000   # ~200K input at LLAMA_CTX=262144, leaves ~56K output/thinking
# MAX_EMBED_INPUT_TOKENS=16384   # must match LXC 151 per-slot embed ctx
# RATE_LIMIT_CHAT=60/minute
# RATE_LIMIT_EMBED=200/minute
# RATE_LIMIT_TAVILY=30/minute
# METRICS_ALLOWED_IPS=127.0.0.1,192.168.6.150   # Proxmox host (Prometheus scrape source)
# CORS_ALLOW_ORIGINS=*                          # comma-separated, or "*" — see router-app.py

# Tavily Search API key — enables /v1/tavily/search proxy AND any Tavily-based
# tools (tavily_search, tavily_extract, tavily_crawl, tavily_map) when used
# under server-side tool execution. Server-side only, never sent to clients.
# Get a key at https://tavily.com (free tier = 1k searches/mo).
# Required for the Weekly Customer Adoption Review artifact's automated
# Refresh-from-web flow. Endpoint returns an error envelope if this is empty.
# TAVILY_API_KEY=tvly-...

# Server-side tool execution. When a chat-completion request includes
# `"tool_execution": "server"`, the router runs the OpenAI tools/tool_calls
# multi-turn loop internally — executes Tavily and web_fetch tools server-side,
# feeds results back into the conversation, returns only the final answer to
# the client. Default "client" preserves legacy pass-through behavior
# (OpenCode / Cline / Continue handle tool_calls themselves). MAX_TOOL_ITERATIONS
# caps the loop to prevent runaways.
# MAX_TOOL_ITERATIONS=10
# TOOL_EXECUTION_DEFAULT=client

# web_fetch tool safety caps. Direct HTTPS GET only; loopback / private ranges
# / metadata services are denied at the application layer (hardcoded in
# router-app.py).
# WEB_FETCH_MAX_SIZE_KB=1024
# WEB_FETCH_TIMEOUT_SECONDS=15

# ---------- AnythingLLM env-config (54-lxc-anythingllm.sh) ----------
# ALLM_LLM_MODEL must match LLAMA_ALIAS in 51. ALLM_EMBED_MODEL must match EMBED_ALIAS.
# Token limit MUST equal or be less than LLAMA_CTX (131072); 262144 in older configs
# was a silent-failure bug — see Step 8.6 warning in setup-runbook.md.
# ALLM_LLM_MODEL=rag-qwen3.6
# ALLM_LLM_TOKEN_LIMIT=131072
# ALLM_EMBED_MODEL=qwen3-embed
# ALLM_EMBED_MAX_CHUNK=16384
# AnythingLLM uses ROUTER_API_KEY as its OpenAI-API-key value. Set this after 53 runs:
# ALLM_ROUTER_API_KEY=                   # paste the value of ROUTER_API_KEY from LXC 153
# Generated and saved to /var/lib/anythingllm-secrets.env on first run.
# ALLM_JWT_SECRET=
# ALLM_SIG_KEY=
# ALLM_SIG_SALT=

# ---------- AnythingLLM API-driven workspace setup (57-configure-anythingllm.sh) ----------
# Generated via Settings -> API Keys after first UI signup. Required for phase 57.
# ALLM_API_KEY=
# Optional: override the default workspace list. Each entry: slug|prompt|topN|refusal
# WORKSPACES=("custom-ws|You are...|10|Not found.")

# ---------- fan control (Phase 5.13) ----------
# Motherboard PWM file(s) that the V620 shroud fans plug into. Two topologies:
#
#   (a) ONE PWM drives everything (Lancool 217 built-in PWM hub model — V620 shroud
#       fans + case stock fans share one curve). Set a single path:
#       FAN_PWM_PATH=/sys/class/hwmon/hwmon3/pwm4
#
#   (b) Each V620 shroud fan on its own motherboard header (e.g., CHA_FAN4 and
#       CHA_FAN5 carrying one shroud fan each, case fans on a separate quiet curve).
#       Set space- or comma-separated list:
#       FAN_PWM_PATH="/sys/class/hwmon/hwmon3/pwm5 /sys/class/hwmon/hwmon3/pwm6"
#
# Discover with `sensors-detect --auto` + `sensors`, then probe each pwmN manually
# (echo 1 > .../pwmN_enable; echo 64 > .../pwmN to drop to 25%; echo 255 to ramp).
# Leave empty to skip fan-bridge installation.
# FAN_PWM_PATH=

# ---------- v1 host migration (Phase 10) ----------
# SSH alias or hostname:port of the old T7910 host. Leave empty to skip migration.
# OLD_HOST=
