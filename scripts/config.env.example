# config.env — central configuration for local-gpu-cluster bootstrap.
# Copy this to config.env and adjust values for your hardware.
#
# Every value has a sane default; uncomment to override.

# ---------- LXC VMIDs ----------
# AMD_VMID=151
# NV_VMID=152
# ROUTER_VMID=153
# ANYTHINGLLM_VMID=154
# MCP_VMID=155

# ---------- hostnames ----------
# AMD_HOSTNAME=llamacpp-amd
# NV_HOSTNAME=llamacpp-nv
# ROUTER_HOSTNAME=llm-router
# ANYTHINGLLM_HOSTNAME=anythingllm
# MCP_HOSTNAME=mcp-stack

# ---------- LXC sizing ----------
# AMD_CORES=8        ; AMD_MEMORY=32768 ; AMD_SWAP=8192 ; AMD_ROOTFS_SIZE=64
# NV_CORES=4         ; NV_MEMORY=16384  ; NV_SWAP=4096 ; NV_ROOTFS_SIZE=48
# ROUTER_CORES=2     ; ROUTER_MEMORY=4096  ; ROUTER_ROOTFS_SIZE=8
# ANYTHINGLLM_CORES=4; ANYTHINGLLM_MEMORY=8192 ; ANYTHINGLLM_ROOTFS_SIZE=32
# MCP_CORES=2        ; MCP_MEMORY=4096  ; MCP_ROOTFS_SIZE=16

# ---------- networking ----------
# BRIDGE=vmbr0
# Static IPs assumed for service routing. Either reserve via DHCP or set explicit IPs
# in your router. The router LXC reads V620_URL / EMBED_URL / RERANK_URL from env.
# AMD_IP=192.168.6.151
# NV_IP=192.168.6.152
# ROUTER_IP=192.168.6.153
# ANYTHINGLLM_IP=192.168.6.154
# MCP_IP=192.168.6.155

# ---------- storage ----------
# Path on the host where ZFS pool 'tank' lives. Datasets created by Phase 4:
#   tank/models       (read-only mount in AMD + NV LXCs at /opt/models)
#   tank/anythingllm  (mounted in 154 at /opt/anythingllm-data)
#   tank/mcp
#   tank/backups
# SECONDARY_NVME=/dev/nvme1n1   # device for `zpool create tank`. Set explicitly.
# MODELS_DIR=/tank/models
# LXC_STORAGE=local-zfs         # PVE storage where LXC rootfs live

# ---------- Proxmox template ----------
# Run `pveam available --section system | grep ubuntu-24` to see current versions.
# LXC_TEMPLATE_NAME=ubuntu-24.04-standard_24.04-2_amd64.tar.zst
# LXC_TEMPLATE_STORAGE=local

# ---------- kernel pin (Phase 4.1) ----------
# Proxmox 9.1 ships kernel 6.17 which has DKMS build failures with current NVIDIA
# packages. Pin to a 6.14 series kernel before installing NVIDIA.
# Set to empty string to skip pinning (only do this if uname -r already shows 6.14.x).
# PIN_KERNEL=auto       # auto = detect newest installed 6.14.x-pve and pin it
                        # empty = skip
                        # "6.14.11-5-pve" = pin this exact version

# ---------- NVIDIA driver ----------
# Driver version installed on the HOST. The LXC must use the same userspace version.
# Check https://www.nvidia.com/en-us/drivers/ for current 580.x. Verified-working values:
#   580.95.05, 580.105.06, 580.126.09
# NVIDIA_DRIVER_VERSION=580.105.06

# ---------- ROCm ----------
# Use 'latest' to pull the current stable amdgpu-install package, or pin to a
# specific release like '6.4' for stability.
# ROCM_RELEASE=latest

# ---------- llama.cpp build target ----------
# V620 = gfx1030 ; RTX 3060 = sm_86 (CUDA arch 86).
# AMD_GPU_TARGET=gfx1030
# NV_CUDA_ARCH=86

# ---------- V620 main LLM tuning (51-lxc-amd.sh) ----------
# Defaults: Qwen3.6-35B-A3B Q4_K_M (22 GB) + 256K ctx + q8_0 KV (~32 GB at 256K).
# Total ~54 GB fits comfortably in 64 GB (2x V620 32 GB).
# LLAMA_HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
# LLAMA_HF_QUANT=UD-Q4_K_M
# LLAMA_ALIAS=qwen3.6-coder
# LLAMA_CTX=262144         # 256K; set 131072 for 128K and ~16 GB of KV
# LLAMA_KV_TYPE=q8_0       # q4_0 halves KV size if you need more headroom
# LLAMA_PARALLEL=2
# LLAMA_TENSOR_SPLIT=1,1
# LLAMA_THREADS=8

# Speculative-decoding draft (in-process on V620 LXC, same HIP backend).
# Qwen3-0.6B shares the Qwen tokenizer family. Set repo="" to disable spec decode.
# LLAMA_DRAFT_REPO=unsloth/Qwen3-0.6B-GGUF
# LLAMA_DRAFT_QUANT=Q4_K_M
# LLAMA_SPEC_NMAX=16
# LLAMA_SPEC_NMIN=0

# ---------- 3060 services (52-lxc-nv.sh) ----------
# Embedder: Qwen3-Embedding-0.6B (1024-dim, MRL-truncatable to 32-1024)
# EMBED_HF_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
# EMBED_HF_QUANT=Q8_0
# EMBED_CTX=32768
# Reranker: bge-reranker-v2-m3
# RERANK_HF_REPO=gpustack/bge-reranker-v2-m3-GGUF
# RERANK_HF_QUANT=Q4_K_M
# RERANK_CTX=8192
# Fast-chat: Qwen3-4B-Instruct on port 8081 for sub-second replies.
# Set FAST_HF_REPO="" to skip the fast-chat unit.
# FAST_HF_REPO=unsloth/Qwen3-4B-Instruct-2507-GGUF
# FAST_HF_QUANT=Q4_K_M
# FAST_ALIAS=qwen3-4b-fast
# FAST_CTX=32768
# FAST_PARALLEL=4

# ---------- Router (53-lxc-router.sh) ----------
# Aliases routed to FAST_URL (3060). Comma-separated. Must include FAST_ALIAS.
# FAST_ALIASES=qwen3-4b-fast
# KEEPALIVE_INTERVAL=12

# ---------- AnythingLLM env-config (54-lxc-anythingllm.sh) ----------
# ALLM_LLM_MODEL must match LLAMA_ALIAS in 51. ALLM_EMBED_MODEL must match
# the embedder alias in 52. Token limit must match LLAMA_CTX or smaller.
# ALLM_LLM_MODEL=qwen3.6-coder
# ALLM_LLM_TOKEN_LIMIT=262144
# ALLM_EMBED_MODEL=qwen3-embedding
# ALLM_EMBED_MAX_CHUNK=8192
# Generated and saved to /var/lib/anythingllm-secrets.env on first run.
# ALLM_JWT_SECRET=
# ALLM_SIG_KEY=
# ALLM_SIG_SALT=

# ---------- AnythingLLM API-driven workspace setup (57-configure-anythingllm.sh) ----------
# Generated via Settings -> API Keys after first UI signup. Required for phase 57.
# ALLM_API_KEY=
# Optional: override the default workspace list. Each entry: slug|prompt|topN|refusal
# WORKSPACES=("custom-ws|You are...|10|Not found.")

# ---------- fan control (Phase 5.13) ----------
# Path to the motherboard PWM file controlling the V620 shroud fans.
# Discover with `sensors-detect --auto` then `sensors`, and bash one-shot
# test (echo 64 > .../pwmN; echo 255 > .../pwmN) to find the right pwmN.
# Leave empty to skip fan-bridge installation (the publisher inside LXC 151
# still runs harmlessly if installed).
# FAN_PWM_PATH=/sys/class/hwmon/hwmon3/pwm4

# ---------- v1 host migration (Phase 10) ----------
# SSH alias or hostname:port of the old T7910 host. Leave empty to skip migration.
# OLD_HOST=
