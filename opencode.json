{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "router": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local GPU Cluster Router",
      "options": {
        "baseURL": "http://192.168.6.153:8000/v1",
        "apiKey": "{env:ROUTER_API_KEY}"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3 Coder (router)",
          "limit": { "context": 131072, "output": 32768 }
        }
      }
    }
  },
  "model": "router/qwen3-coder",
  "mcp": {
    "memory": {
      "type": "remote",
      "url": "http://192.168.6.223:3005/mcp?space=local-gpu-cluster",
      "enabled": true
    }
  }
}
